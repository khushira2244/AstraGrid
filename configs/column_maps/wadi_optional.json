
{
  "dataset_id": "wadi_optional",
  "dataset_name": "WADI Water Distribution Dataset",
  "raw_folder": "data/raw/wadi_optional",
  "primary_file": "WADI_attackdataLABLE.csv",
  "normal_file": "WADI_14days_new.csv",

  "backend_role": "optional_large_water_distribution_agent_input",

  "preprocessing": {
    "skiprows": 1,
    "strip_column_names": true,
    "read_strategy": "chunked_or_sampled",
    "reason": "File has numeric header row followed by real header row and is large."
  },

  "time": {
    "date_column": "Date",
    "time_column": "Time"
  },

  "label": {
    "column": "Attack LABLE (1:No Attack, -1:Attack)",
    "classes": {
      "1": "normal_operation",
      "-1": "water_distribution_attack"
    }
  },

  "column_groups": {
    "sensors": {
      "description": "WADI process sensor measurements",
      "include_keywords": ["AIT", "FIT", "LT", "DPIT", "PIT", "PV"]
    },
    "actuators": {
      "description": "WADI pumps, valves, and status/control columns",
      "include_keywords": ["P_", "MV", "STATUS", "CO", "SP"]
    },
    "demand_or_consumption": {
      "description": "Consumer demand / required flow fields",
      "include_keywords": ["CONS", "FLOW"]
    }
  },

  "agent_outputs": {
    "large_water_distribution_agent": [
      "large_scale_water_anomaly_summary",
      "sensor_evidence",
      "actuator_evidence",
      "attack_label_evidence",
      "scalability_extension_status"
    ]
  },

  "normalized_event_mapping": {
    "sector": "water",
    "source_dataset": "wadi_optional",
    "asset_scope": "Large water distribution telemetry",
    "event_type_from_label": {
      "1": "water_distribution_normal_operation",
      "-1": "water_distribution_attack"
    },
    "evidence_sources": [
      "sensors",
      "actuators",
      "demand_or_consumption"
    ]
  },

  "inspection_result": {
    "inspected_file": "WADI_attackdataLABLE.csv",
    "rows_inspected": 5000,
    "columns": 131,
    "label_column": "Attack LABLE (1:No Attack, -1:Attack)",
    "observed_class_counts_in_first_5000_rows": {
      "1": 5000
    },
    "status": "optional_adapter_accepted"
  }
}
